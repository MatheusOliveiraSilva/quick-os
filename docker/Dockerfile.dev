FROM rust:1.83-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    extlinux \
    e2fsprogs \
    ca-certificates \
    kmod \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Firecracker runs only when /dev/kvm is passed through.
CMD ["bash", "-lc", "scripts/setup-dev.sh && cargo build && cargo run -p quick-os -- check-env"]
